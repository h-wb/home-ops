{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>h-wb/home-ops//.renovate/autoMerge.json5",
    "github>h-wb/home-ops//.renovate/changelogs.json5",
    "github>h-wb/home-ops//.renovate/customManagers.json5",
    "github>h-wb/home-ops//.renovate/grafanaDashboards.json5",
    "github>h-wb/home-ops//.renovate/groups.json5",
    "github>h-wb/home-ops//.renovate/labels.json5",
    "github>h-wb/home-ops//.renovate/overrides.json5",
    "github>h-wb/home-ops//.renovate/semanticCommits.json5",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/New_York)",
  ],
  // Enable GitHub-native auto-merge on every PR. The merge is gated by branch
  // protection (1 required approval + required checks); the Claude "Renovate PR
  // Review" workflow supplies that approval, so only Claude-approved bumps merge.
  automerge: true,
  automergeType: "pr",
  platformAutomerge: true,
  // Only rebase on an actual conflict — avoids re-firing the Claude review +
  // CI every time a PR falls behind main (branch protection isn't strict).
  rebaseWhen: "conflicted",
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  ignorePaths: ["**/resources/**", "**/*.sops.*"],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
